generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id                  String   @id
  title               String
  slug                String   @unique
  enabled             Boolean  @default(true)
  catalogVisible      Boolean  @default(true)
  portionWeight       Int
  portionUnit         String
  productCategories   String[] @default([])
  featureImageUrl     String
  productImageGallery String[] @default([])
  isNewArrival        Boolean  @default(false)
  newArrivalOrder     Int      @default(0)
  shortDescription    String
  longDescription     String
  regularPrice        String
  salePrice           String   @default("")
  currency            String   @default("RUR")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([catalogVisible])
  @@index([enabled])
  @@index([isNewArrival, newArrivalOrder])
  @@map("products")
}

model UploadedImage {
  id           String   @id
  originalName String
  mimeType     String
  size         Int
  bytes        Bytes
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@map("uploaded_images")
}

model HomepageSettings {
  id                    String   @id
  recentProductsEnabled Boolean  @default(true)
  weeklyOffersEnabled   Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("homepage_settings")
}

model IdempotencyRequest {
  id          String   @id @default(cuid())
  key         String
  endpoint    String
  requestHash String
  statusCode  Int
  responseBody Json
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  @@unique([key, endpoint])
  @@index([expiresAt])
  @@map("idempotency_requests")
}
