# ==============================================
# K-nig-Food Environment Variables Example
# ==============================================

# ----------------------------------------------
# Gmail SMTP Settings
# Используется для отправки:
# - Подтверждений заказов
# - Уведомлений администратору
# - Сообщений с контактной формы
# ----------------------------------------------

# Основной email отправителя
# Формат: email@gmail.com
GMAIL_USER=your-gmail@gmail.com

# App Password Gmail (НЕ пароль от аккаунта!)
# Получить можно здесь:
# https://myaccount.google.com/apppasswords
# Включите 2FA и создайте app password
GMAIL_APP_PASSWORD=your-gmail-app-password


# ----------------------------------------------
# GitHub OAuth Authentication
# Используется для входа сотрудников в админку
# ----------------------------------------------

# OAuth Client ID GitHub App
GITHUB_CLIENT_ID=github-client-id

# OAuth Client Secret GitHub App
GITHUB_CLIENT_SECRET=github-client-secret

# Email администратора (разрешённый для входа)
# Только этот email может войти в админку
# ADMIN_EMAIL=твоя_почта_на_github
ADMIN_EMAIL=admin-email@gmail.com


# ----------------------------------------------
# NextAuth Settings
# ----------------------------------------------

# Base URL приложения
# Для локальной разработки: http://localhost:3000
# Для production: https://your-domain.com
NEXTAUTH_URL=https://your-domain.com

# JWT Secret для подписи токенов
# Сгенерировать можно здесь: через терминал: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=generate-random-secret

# ----------------------------------------------
# Yandex Maps (Checkout delivery map)
# ----------------------------------------------
# Публичный ключ JS API Яндекс Карт (кабинет разработчика Яндекс)
# Используется на клиенте, поэтому обязательно с префиксом NEXT_PUBLIC_
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=your-yandex-maps-js-api-key
# Необязательно: точные координаты точки самовывоза (если нужно вручную скорректировать)
NEXT_PUBLIC_PICKUP_LAT=54.7257
NEXT_PUBLIC_PICKUP_LNG=20.4729


# ----------------------------------------------
# PostgreSQL Database
# Используется для хранения каталога товаров
# ----------------------------------------------

# ВАЖНО:
# Prisma и приложение читают только DATABASE_URL и DIRECT_URL.
# Для локальной разработки направляем их на *_DEV через подстановку.
DATABASE_URL=${DATABASE_URL_DEV}
DIRECT_URL=${DIRECT_URL_DEV}

# Пароль облачной БД (Supabase/Postgres) для сборки *_PROD строк.
# Используется только как подстановка в DATABASE_URL_PROD и DIRECT_URL_PROD.
# В Vercel можно хранить только готовые DATABASE_URL / DIRECT_URL без этой переменной.
CLOUD_DB_PASS=your-cloud-db-password

# --- Local DEV (используется на вашем компьютере) ---
# Локальный Postgres из docker-compose:
# postgresql://knig_food_user:knig_food_password@localhost:3550/knig_food?schema=public
DATABASE_URL_DEV=postgresql://knig_food_user:knig_food_password@localhost:3550/knig_food?schema=public
DIRECT_URL_DEV=postgresql://knig_food_user:knig_food_password@localhost:3550/knig_food?schema=public

# --- Production (Supabase / Vercel) ---
# Эти переменные локально не используются.
# В Vercel нужно добавить:
# DATABASE_URL = значение DATABASE_URL_PROD
# DIRECT_URL   = значение DIRECT_URL_PROD
DATABASE_URL_PROD=postgresql://postgres.project-ref:${CLOUD_DB_PASS}@aws-1-xxx.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require
DIRECT_URL_PROD=postgresql://postgres.project-ref:${CLOUD_DB_PASS}@aws-1-xxx.pooler.supabase.com:5432/postgres?sslmode=require
